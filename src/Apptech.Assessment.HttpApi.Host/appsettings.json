{
  "App": {
    "SelfUrl": "https://localhost:44382",
    "AngularUrl": "http://localhost:4200",
    "CorsOrigins": "https://*.Assessment.com,http://localhost:4200,",
    "RedirectAllowedUrls": "http://localhost:4200,",
    "DisablePII": false,
    "HealthCheckUrl": "/health-status"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Information",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "Enrich": [
      "FromLogContext"
    ],
    "WriteTo": [
      {
        "Name": "Async",
        "Args": {
          "configure": [
            {
              "Name": "File",
              "Args": {
                "path": "Logs/logs.txt"
              }
            }
          ]
        }
      },
      {
        "Name": "Async",
        "Args": {
          "configure": [
            {
              "Name": "Console"
            }
          ]
        }
      }
    ]
  },
  "ConnectionStrings": {
    "Default": "Host=localhost;Port=5432;Database=Assessment;Username=root;Password=myPassword;"
  },
  "Redis": {
    "IsEnabled": "true",
    "Configuration": "localhost:6379"
  },
  "AuthServer": {
    "Authority": "https://localhost:44382",
    "RequireHttpsMetadata": true,
    "SwaggerClientId": "Assessment_Swagger",
    "CertificatePassPhrase": "aee39cff-38cf-49b8-aa72-e5d0c6509c44"
  },
  "StringEncryption": {
    "DefaultPassPhrase": "QAJmvA9o8zn3yvN4"
  }
}